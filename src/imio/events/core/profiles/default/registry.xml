<?xml version="1.0"?>
<registry
    xmlns:i18n="http://xml.zope.org/namespaces/i18n"
    i18n:domain="imio.smartweb">

    <record name="geolocation.default_latitude"
            interface="plone.formwidget.geolocation.interfaces.IGeolocationSettings">
      <value>50.4989185</value>
    </record>

    <record name="geolocation.default_longitude"
            interface="plone.formwidget.geolocation.interfaces.IGeolocationSettings">
      <value>4.7184485</value>
    </record>

    <record name="geolocation.use_default_geolocation_as_value"
            interface="plone.formwidget.geolocation.interfaces.IGeolocationSettings">
      <value>False</value>
    </record>

  <record name="plone.types_not_searched"
            interface="Products.CMFPlone.interfaces.controlpanel.ISearchSchema"
            field="types_not_searched">
      <value purge="false">
        <element>News Item</element>
        <element>Collection</element>
        <element>Discussion Item</element>
        <element>Folder</element>
        <element>File</element>
        <element>Image</element>
        <element>Link</element>
        <element>Document</element>
        <element>Plone Site</element>
        <element>TempFolder</element>
        <element>Event</element>
      </value>
    </record>

  <record name="imio.events.core.odwb_entites-des-agendas-en-wallonie_pushkey">
    <field type="plone.registry.field.TextLine">
      <title>ODWB : Entit&#233;s des agendas en Wallonie - pushkey</title>
    </field>
  </record>

  <record name="imio.events.core.odwb_evenements-en-wallonie_pushkey">
    <field type="plone.registry.field.TextLine">
      <title>ODWB : Evenements en Wallonie - pushkey</title>
    </field>
  </record>

  <record name="imio.events.core.odwb_staging-entites-des-agendas-en-wallonie_pushkey">
    <field type="plone.registry.field.TextLine">
      <title>ODWB : Entit&#233;s des agendas en Wallonie (STAGING) - pushkey</title>
    </field>
  </record>

  <record name="imio.events.core.odwb_staging-evenements-en-wallonie_pushkey">
    <field type="plone.registry.field.TextLine">
      <title>ODWB : Evenements en Wallonie (STAGING) - pushkey</title>
    </field>
  </record>

  <record name="plone.portal_timezone">
    <value>Europe/Brussels</value>
  </record>

  <record name="plone.available_timezones">
    <value purge="true">
      <element>Europe/Brussels</element>
    </value>
  </record>

  <record name="plone.first_weekday">
    <value>0</value>
  </record>

  <records prefix="plone.bundles/imio-events-core-edit"
           interface='Products.CMFPlone.interfaces.IBundleRegistry'>
    <value key="enabled">True</value>
    <value key="expression">python: member is not None</value>
    <value key="jscompilation">++plone++imio.events.core/directory_contact_autofill.js</value>
    <value key="depends">plone</value>
    <value key="load_async">False</value>
    <value key="load_defer">False</value>
  </records>

</registry>
